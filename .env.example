# Скопируй этот файл в ".env" и заполни своими данными.
# Файл ".env" НЕ коммитится (см. .gitignore) — храни пароль только в нём.

# Строка подключения к Supabase (Project Settings -> Database -> Connection
# string -> URI). Схему замени на postgresql+psycopg2://. Если прямое
# подключение db.<ref>.supabase.co не коннектится — возьми "Session pooler"
# (порт 5432, логин вида postgres.<ref>).
DATABASE_URL=postgresql+psycopg2://postgres.YOUR-REF:ПАРОЛЬ@aws-0-REGION.pooler.supabase.com:5432/postgres

# Секрет для подписи токенов входа — любая длинная случайная строка.
SECRET_KEY=change-me-to-a-long-random-string
